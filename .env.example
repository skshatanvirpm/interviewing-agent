# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_REQUIRE_ACCESS_TOKEN=false
NEXT_OUTPUT_EXPORT=false

# OpenAI
OPENAI_API_KEY=
OPENAI_INTERVIEW_MODEL=gpt-5.4
OPENAI_RESUME_PARSE_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin

# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App behavior
INTERVIEW_REASONING_EFFORT=low
INTERVIEWER_NAME=Alex
INTERVIEW_TARGET_ROLE=Machine Learning Engineer
INTERVIEW_TARGET_COMPANY=Example Company
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
API_ACCESS_TOKEN=
API_RATE_LIMIT_PER_MINUTE=0
SESSION_ACCESS_HEADER=X-Interview-Session-Token
INTERVIEW_DATA_RETENTION_DAYS=30
INTERVIEW_RETENTION_CLEANUP_ENABLED=true
MAX_RESUME_UPLOAD_BYTES=10485760
MAX_AUDIO_UPLOAD_BYTES=26214400
LOG_LEVEL=INFO
